    <description>When Contact Role is changed to &quot;Primary Billing Contact&quot; or &quot;Additional Billing Contact&quot;, send notification to the Accounting Team of relevant BM Entity.</description>
    <environments>Default</environments>
    <formulas>
        <name>recordURL</name>
        <dataType>String</dataType>
        <expression>LEFT($Api.Partner_Server_URL_260, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_260)) + {!$Record.Id}</expression>
    </formulas>
    <formulas>
        <name>subject</name>
        <dataType>String</dataType>
        <expression>&quot;Billing Contact role changed for Contact &quot; + {!$Record.FirstName} + &quot; &quot; + {!$Record.LastName}</expression>
    </formulas>
    <interviewLabel>Notify Accounting Team when Billing Contact Role is Changed {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Notify Accounting Team when Billing Contact Role is Changed</label>
