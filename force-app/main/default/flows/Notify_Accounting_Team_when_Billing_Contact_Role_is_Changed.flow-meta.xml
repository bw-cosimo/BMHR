    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Country_BM_Entity_Mapping</targetReference>
        </connector>
        <filterFormula>AND(
ISCHANGED({!$Record.Role__c}),
OR(
ISPICKVAL({!$Record.Role__c}, &apos;Primary Billing Contact&apos;),
ISPICKVAL({!$Record.Role__c}, &apos;Additional Billing Contact&apos;)
)
)</filterFormula>
        <object>Contact</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
