<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Populate KYC Related Entity External Id field when record is created or updated.</description>
    <environments>Default</environments>
    <formulas>
        <name>externalId</name>
        <dataType>String</dataType>
        <expression>{!$Record.KYC_Response__c} + {!$Record.Email__c} + {!$Record.Legal_Company_Name__c}</expression>
    </formulas>
    <interviewLabel>Populate KYC Related Entity External Id {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Populate KYC Related Entity External Id</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_External_Id</name>
        <label>Update External Id</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>External_Id__c</field>
            <value>
                <elementReference>externalId</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_External_Id</targetReference>
        </connector>
        <object>KYC_Response_Related_Entities__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
