    <decisions>
        <description>Runs when any of the three Entities types (Contracting, Servicing or Billing) is Benefit related (is Black Mountain Global Benefits OR Black Mountain Employee Benefits).</description>
        <name>Opportunity_Current_Entities_Are</name>
        <label>Opportunity Current Entities Are</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_Opportunity_Set_Warning_Flag_and_Assign_Fee_Reviewer</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Different</defaultConnectorLabel>
        <rules>
            <name>Blank_or_Same</name>
            <conditionLogic>(1 OR 4) AND (2 OR 5) AND (3 OR 6)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Opportunity.Servicing_Entity__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>servicingEntity</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Opportunity.Contracting_Entity__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>contractingEntity</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Opportunity.Billing_Entity__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>billingEntity</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Opportunity.Servicing_Entity__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Opportunity.Contracting_Entity__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Opportunity.Billing_Entity__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Opportunity</targetReference>
            </connector>
            <label>Blank or Same</label>
        </rules>
        <rules>
            <name>Benefit_Related</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>newEntityIsBenefitRelated</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>prevValueIsSet</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>prevValueIsNOTBenefitRelated</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Prevent_Adding_Product_Benefits_Only</targetReference>
            </connector>
            <label>Benefit Related</label>
        </rules>
    </decisions>
    <description>Calculate BM Entities (Servicing, Contracting and Invoicing) when Opportunity Product is created.</description>
    <environments>Default</environments>
    <formulas>
        <name>newEntityIsBenefitRelated</name>
        <dataType>Boolean</dataType>
        <expression>OR(
{!servicingEntity} = &apos;BMEB&apos;, 
{!servicingEntity} = &apos;BMGB&apos;,
{!contractingEntity} = &apos;BMEB&apos;, 
{!contractingEntity} = &apos;BMGB&apos;,
{!billingEntity} = &apos;BMEB&apos;, 
{!billingEntity} = &apos;BMGB&apos;
)</expression>
    </formulas>
    <formulas>
        <name>prevValueIsNOTBenefitRelated</name>
        <dataType>Boolean</dataType>
        <expression>AND(
NOT(ISPICKVAL({!$Record.Opportunity.Servicing_Entity__c},&apos;BMEB&apos;)),
NOT(ISPICKVAL({!$Record.Opportunity.Servicing_Entity__c},&apos;BMGB&apos;)),
NOT(ISPICKVAL({!$Record.Opportunity.Billing_Entity__c},&apos;BMEB&apos;)),
NOT(ISPICKVAL({!$Record.Opportunity.Billing_Entity__c},&apos;BMGB&apos;)),
NOT(ISPICKVAL({!$Record.Opportunity.Contracting_Entity__c},&apos;BMEB&apos;)),
NOT(ISPICKVAL({!$Record.Opportunity.Contracting_Entity__c},&apos;BMGB&apos;))
)</expression>
    </formulas>
    <formulas>
        <name>prevValueIsSet</name>
        <dataType>Boolean</dataType>
        <expression>OR(
NOT(ISBLANK(TEXT({!$Record.Opportunity.Servicing_Entity__c}))),
NOT(ISBLANK(TEXT({!$Record.Opportunity.Billing_Entity__c}))),
NOT(ISBLANK(TEXT({!$Record.Opportunity.Billing_Entity__c})))
)</expression>
    </formulas>
    <interviewLabel>Calculate BM Entities when Opportunity Product is Created {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Calculate BM Entities when Opportunity Product is Created</label>
