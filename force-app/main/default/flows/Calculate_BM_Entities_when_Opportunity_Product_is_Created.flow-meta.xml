    <decisions>
        <name>Is_Billing_Account_Same_as_Servicing</name>
        <label>Is Billing Account Same as Servicing?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Calculate_Billing_Entity_Based_on_Billing_Country</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Same_Account_Billing</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Opportunity.AccountId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Opportunity.Billing_Account__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Billing_Entity</targetReference>
            </connector>
            <label>Same Account</label>
        </rules>
        <rules>
            <name>Is_Billing_Account_Blank</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Opportunity.Billing_Account__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
