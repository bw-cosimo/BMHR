<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>When KYC Form is created, populate selected Contact details with Form details.</description>
    <environments>Default</environments>
    <formulas>
        <name>formSentToPartner</name>
        <dataType>Boolean</dataType>
        <expression>{!$Record.RecordType.DeveloperName} = &apos;Partner_Affiliate_Form&apos;</expression>
    </formulas>
    <formulas>
        <name>formURL</name>
        <dataType>String</dataType>
        <expression>$Setup.KYC_Form_Settings__c.Form_URL__c + {!$Record.Id}</expression>
    </formulas>
    <formulas>
        <name>isNew</name>
        <dataType>Boolean</dataType>
        <expression>ISPICKVAL({!$Record.Scenario__c}, &apos;New&apos;)</expression>
    </formulas>
    <formulas>
        <name>now</name>
        <dataType>DateTime</dataType>
        <expression>NOW()</expression>
    </formulas>
    <interviewLabel>Update Sent To Contact with KYC Form Details {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update Sent To Contact with KYC Form Details</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Contact_from_Sent_To</name>
        <label>Update Contact (from Sent To)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Sent_To__c</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Form_Sent_to_Partner__c</field>
            <value>
                <elementReference>formSentToPartner</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Is_KYC_Form_New__c</field>
            <value>
                <elementReference>isNew</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Last_KYC_Form_Sent_On__c</field>
            <value>
                <elementReference>now</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Last_KYC_Form_URL__c</field>
            <value>
                <elementReference>formURL</elementReference>
            </value>
        </inputAssignments>
        <object>Contact</object>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Contact_from_Sent_To</targetReference>
        </connector>
        <object>KYC_Response__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
