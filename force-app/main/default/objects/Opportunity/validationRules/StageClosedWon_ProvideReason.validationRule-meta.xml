<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>StageClosedWon_ProvideReason</fullName>
    <active>true</active>
    <description>When Opportunity is Closed Won, specify Won Reason(s).</description>
    <errorConditionFormula>AND(
ISCHANGED(StageName),
ISPICKVAL(StageName, &apos;Closed Won&apos;),
ISBLANK(Won_Reasons__c)
)</errorConditionFormula>
    <errorDisplayField>Won_Reasons__c</errorDisplayField>
    <errorMessage>Choose reason why Opportunity was won.</errorMessage>
</ValidationRule>
