<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>StageClosedWon_Contract</fullName>
    <active>true</active>
    <description>When Opportunity is Closed Won, populate the Contract Id.</description>
    <errorConditionFormula>AND(
ISCHANGED(StageName),
ISPICKVAL(StageName, &apos;Closed Won&apos;),
ISBLANK(ContractId)
)</errorConditionFormula>
    <errorDisplayField>ContractId</errorDisplayField>
    <errorMessage>Link Contract.</errorMessage>
</ValidationRule>
