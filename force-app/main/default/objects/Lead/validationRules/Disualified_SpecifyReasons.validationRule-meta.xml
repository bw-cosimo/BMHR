<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Disualified_SpecifyReasons</fullName>
    <active>true</active>
    <description>The Disqualified Reason(s) field must be filled in when Lead is disqualified.</description>
    <errorConditionFormula>AND(
ISCHANGED(Status),
ISPICKVAL(Status, &quot;Unqualified&quot;),
ISBLANK( Disqualified_Reasons__c )
)</errorConditionFormula>
    <errorDisplayField>Disqualified_Reasons__c</errorDisplayField>
    <errorMessage>Specify Disqualified Reason(s).</errorMessage>
</ValidationRule>
